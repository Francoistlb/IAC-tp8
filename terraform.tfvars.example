# EXEMPLE DE CONFIGURATION - Copier et renommer en terraform.tfvars
# NE PAS VERSIONNER terraform.tfvars avec les vraies valeurs !

environment = "dev"

db_password = "your_secure_password_here"
api_key     = "your_api_key_here"
app_secret  = "your_app_secret_here"

services = {
  frontend = {
    name          = "frontend"
    image         = "nginx:latest"
    port_internal = 80
    port_external = 8090
    environment   = "dev"
    replicas      = 1
    enable        = true
  }
  backend = {
    name          = "backend"
    image         = "node:18-alpine"
    port_internal = 3000
    port_external = 8091
    environment   = "dev"
    replicas      = 1
    enable        = false
  }
  database = {
    name          = "database"
    image         = "postgres:15-alpine"
    port_internal = 5432
    port_external = 8092
    environment   = "dev"
    replicas      = 1
    enable        = false
  }
  cache = {
    name          = "cache"
    image         = "redis:7-alpine"
    port_internal = 6379
    port_external = 8093
    environment   = "dev"
    replicas      = 1
    enable        = true
  }
}
